# [Created by task 3.4.2 3/26/2026 16:17:24]
data.location=/Users/illico/.task
news.version=3.4.2

# To use the default location of the XDG directories,
# move this configuration file from ~/.taskrc to ~/.config/task/taskrc and update location config as follows:

#data.location=~/.local/share/task
#hooks.location=~/.config/task/hooks

# Color theme (uncomment one to use)
#include light-16.theme
#include light-256.theme
#include bubblegum-256.theme
#include dark-16.theme
#include dark-256.theme
#include dark-red-256.theme
#include dark-green-256.theme
#include dark-blue-256.theme
#include dark-violets-256.theme
#include dark-yellow-green.theme
#include dark-gray-256.theme
#include dark-gray-blue-256.theme
#include solarized-dark-256.theme
#include solarized-light-256.theme
#include no-color.theme

# Remove background colors, keep foreground colors
color.alternate=color15
color.active=rgb555
color.blocked=white
color.blocking=color15
color.burndown.done=white on rgb010
color.burndown.pending=white on color9
color.burndown.started=white on color11
color.calendar.due=color11
color.calendar.due.today=color0 on color11
color.calendar.holiday=color13
color.calendar.overdue=color1
color.calendar.scheduled=color6
color.calendar.today=color0 on color2
color.calendar.weekend=color245
color.calendar.weeknumber=color240
color.error=red
color.history.add=rgb500
color.history.delete=rgb550
color.history.done=rgb050
color.scheduled=
color.summary.background=
color.summary.bar=rgb141

# Hide annotations in list view, truncate long descriptions
report.list.columns=id,uuid.short,start.age,entry.age,depends.indicator,priority,project,tags,recur.indicator,scheduled.relative,due.relative,until.remaining,description.truncated,effort,urgency
report.list.labels=ID,UUID,Active,Age,Dep,P,Project,Tag,Recur,Sched,Due,Until,Description,Effort,Urg
report.list.filter=status:pending or status:completed
report.list.sort=status-,urgency-

# Completed tasks shown in red
color.completed=red

# Custom 'notes' report - shows annotations only
report.notes.description=Shows annotations for a task
report.notes.columns=id,description
report.notes.labels=ID,Notes
report.notes.filter=status:pending

# UDA for note tracking
uda.note.type=date
uda.note.label=Note

# UDA for effort tracking
# effort: any positive float 0.1-20 (higher = harder)
# Low effort = higher urgency (quick wins first)
# Hook rounds effort to nearest int, stores in effort_urg
# Urgency contribution = effort_urg * -0.5
uda.effort.type=string
uda.effort.label=Effort
uda.effort_urg.type=string
uda.effort_urg.label=EUrg
urgency.uda.effort_urg.1.coefficient=-0.5
urgency.uda.effort_urg.2.coefficient=-1.0
urgency.uda.effort_urg.3.coefficient=-1.5
urgency.uda.effort_urg.4.coefficient=-2.0
urgency.uda.effort_urg.5.coefficient=-2.5
urgency.uda.effort_urg.6.coefficient=-3.0
urgency.uda.effort_urg.7.coefficient=-3.5
urgency.uda.effort_urg.8.coefficient=-4.0
urgency.uda.effort_urg.9.coefficient=-4.5
urgency.uda.effort_urg.10.coefficient=-5.0
urgency.uda.effort_urg.11.coefficient=-5.5
urgency.uda.effort_urg.12.coefficient=-6.0
urgency.uda.effort_urg.13.coefficient=-6.5
urgency.uda.effort_urg.14.coefficient=-7.0
urgency.uda.effort_urg.15.coefficient=-7.5
urgency.uda.effort_urg.16.coefficient=-8.0
urgency.uda.effort_urg.17.coefficient=-8.5
urgency.uda.effort_urg.18.coefficient=-9.0
urgency.uda.effort_urg.19.coefficient=-9.5
urgency.uda.effort_urg.20.coefficient=-10.0

# Default report (task command) with effort column
report.next.columns=id,start.age,entry.age,depends,priority,project,tags,recur,scheduled.relative,due.relative,until.remaining,description.truncated,effort,urgency
report.next.labels=ID,Active,Age,Deps,P,Project,Tag,Recur,S,Due,Until,Description,Effort,Urg

# taskwarrior-tui configuration
# Selection: black background highlight (reverse video)
uda.taskwarrior-tui.selection.bold=no
uda.taskwarrior-tui.selection.italic=no
uda.taskwarrior-tui.selection.dim=no
uda.taskwarrior-tui.selection.blink=no
uda.taskwarrior-tui.selection.reverse=yes
uda.taskwarrior-tui.selection.indicator=•
uda.taskwarrior-tui.style.report.selection=
uda.taskwarrior-tui.shortcuts.1=~/.task/hooks/tui-note
uda.taskwarrior-tui.task-report.prompt-on-done=true
uda.taskwarrior-tui.task-report.show-info=false

# Aliases
alias.note=execute "${HOME}/.task/hooks/note"
alias.select=execute "${HOME}/.task/hooks/select"

