#!/usr/bin/env bash
# Open nvim note buffer for a task in the tt nvim pane.
# Receives task ID as $1 (from taskwarrior-tui shortcut)

NOTE_DIR="$HOME/.task/notes"
NVIM_SOCK=$(cat /tmp/tt-nvim-sock 2>/dev/null)
NVIM_PANE=$(cat /tmp/tt-nvim-pane 2>/dev/null)

mkdir -p "$NOTE_DIR"

uuid=$(task _get "$1".uuid)
[ -z "$uuid" ] && exit 1

note="$NOTE_DIR/${uuid}.md"
[ ! -f "$note" ] && touch "$note"

if [ -n "$NVIM_SOCK" ] && [ -n "$NVIM_PANE" ]; then
    # Send the file to the existing nvim instance and focus its pane
    nvim --server "$NVIM_SOCK" --remote-send "<Esc>:edit $note<CR>" 2>/dev/null
    tmux select-pane -t "$NVIM_PANE"
else
    # Fallback: open nvim directly (outside tt)
    nvim "$note"
    task "$uuid" mod note:"$(date +%Y-%m-%dT%H:%M:%S)" >/dev/null
fi
