#!/usr/bin/env bash
# Launch taskwarrior-tui with an nvim note pane below.
# Press 1 on a task to open its note in the nvim pane.

NVIM_SOCK="/tmp/nvim-task-notes.sock"
NOTE_DIR="$HOME/.task/notes"

mkdir -p "$NOTE_DIR"

# Clean up stale socket
rm -f "$NVIM_SOCK"

# Get current pane (will become the tui pane)
TUI_PANE=$(tmux display-message -p '#{pane_id}')

# Split below: nvim with a server socket
tmux split-window -v -l 50% "nvim --listen $NVIM_SOCK $NOTE_DIR/buffer.md"

# Get the nvim pane ID and save it for the shortcut script
NVIM_PANE=$(tmux display-message -p '#{pane_id}')
echo "$NVIM_PANE" > /tmp/tt-nvim-pane
echo "$NVIM_SOCK" > /tmp/tt-nvim-sock

# Go back to the tui pane
tmux select-pane -t "$TUI_PANE"

# Wait for nvim to start its server
sleep 0.3

# Run taskwarrior-tui (blocks until exit)
taskwarrior-tui

# Cleanup
tmux kill-pane -t "$NVIM_PANE" 2>/dev/null
rm -f "$NVIM_SOCK" /tmp/tt-nvim-pane /tmp/tt-nvim-sock
