#!/usr/bin/env bash
# Launch taskwarrior-tui with a synced nvim note pane below.
# Usage: tt (via alias)

NVIM_SOCK="/tmp/nvim-task-notes.sock"
NOTE_DIR="$HOME/.task/notes"
WATCHER="$HOME/.task/hooks/tt-watcher"

mkdir -p "$NOTE_DIR"

# Clean up stale socket
rm -f "$NVIM_SOCK"

# Get current pane (will become the tui pane)
TUI_PANE=$(tmux display-message -p '#{pane_id}')

# Split below: nvim with a server socket, opens a blank buffer
tmux split-window -v -l 30% "nvim --listen $NVIM_SOCK $NOTE_DIR/buffer.md"

# Get the nvim pane ID
NVIM_PANE=$(tmux display-message -p '#{pane_id}')

# Go back to the tui pane
tmux select-pane -t "$TUI_PANE"

# Wait for nvim to start its server
sleep 0.3

# Start the watcher in background
"$WATCHER" "$TUI_PANE" "$NVIM_SOCK" &
WATCHER_PID=$!

# Run taskwarrior-tui (blocks until exit)
taskwarrior-tui

# Cleanup: kill watcher and nvim pane
kill "$WATCHER_PID" 2>/dev/null
tmux kill-pane -t "$NVIM_PANE" 2>/dev/null
rm -f "$NVIM_SOCK"
