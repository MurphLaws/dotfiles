#!/usr/bin/env bash
# Background watcher: polls taskwarrior-tui pane for selected task,
# tells nvim to open the corresponding note buffer.
#
# Args: $1 = tmux pane ID of taskwarrior-tui, $2 = nvim socket path

TUI_PANE="$1"
NVIM_SOCK="$2"
NOTE_DIR="$HOME/.task/notes"
CACHE_FILE="/tmp/tt-uuid-cache.$$"
last_id=""

mkdir -p "$NOTE_DIR"

# Build ID->UUID cache file (id:uuid per line, no hooks triggered)
refresh_cache() {
    task rc.hooks=off rc.verbose=nothing export status:pending 2>/dev/null | \
        sed -n 's/.*"id":\([0-9]*\).*"uuid":"\([^"]*\)".*/\1:\2/p' > "$CACHE_FILE"
}

lookup_uuid() {
    grep "^${1}:" "$CACHE_FILE" 2>/dev/null | head -1 | cut -d: -f2-
}

refresh_cache

while true; do
    # Check if the tui pane still exists
    tmux has-session -t "$TUI_PANE" 2>/dev/null || break

    # Capture the tui pane and find the selected line (starts with •)
    selected=$(tmux capture-pane -t "$TUI_PANE" -p 2>/dev/null | grep '•')

    if [ -n "$selected" ]; then
        # Extract the task ID (first number after the bullet)
        task_id=$(echo "$selected" | sed 's/•//' | awk '{print $1}')

        if [ -n "$task_id" ] && [ "$task_id" != "-" ] && [ "$task_id" != "$last_id" ]; then
            uuid=$(lookup_uuid "$task_id")

            # Cache miss — refresh once
            if [ -z "$uuid" ]; then
                refresh_cache
                uuid=$(lookup_uuid "$task_id")
            fi

            if [ -n "$uuid" ]; then
                note="$NOTE_DIR/${uuid}.md"
                [ ! -f "$note" ] && touch "$note"
                nvim --server "$NVIM_SOCK" --remote-send "<Esc>:edit $note<CR>" 2>/dev/null
            fi
            last_id="$task_id"
        fi
    fi

    sleep 0.5
done

rm -f "$CACHE_FILE"
