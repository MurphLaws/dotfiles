#!/usr/bin/env python3
"""Map effort to effort_urg (nearest int, clamped 1-20) for urgency."""

import json
import sys

old = json.loads(sys.stdin.readline())
new = json.loads(sys.stdin.readline())

effort = new.get("effort")
if effort:
    val = float(effort)
    if val > 0:
        new["effort_urg"] = str(max(1, min(20, round(val))))
    else:
        new.pop("effort_urg", None)
else:
    new.pop("effort_urg", None)

print(json.dumps(new))
