#!/usr/bin/env python3
"""Compute effort_score = (1/effort)*2 on task modify."""

import json
import sys

old = json.loads(sys.stdin.readline())
new = json.loads(sys.stdin.readline())

effort = new.get("effort")
if effort and float(effort) > 0:
    new["effort_score"] = round(2.0 / float(effort), 4)
else:
    new.pop("effort_score", None)

print(json.dumps(new))
