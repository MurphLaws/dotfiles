#!/usr/bin/env python3
"""
Taskwarrior pending-tasks TUI — fzf-based picker that mirrors the nvim
taskwarrior-notes plugin (same columns, same icons, same actions).

Usage:
    task                              # interactive picker (bare `task` alias)
    .../tui --project-of  <uuid>      # internal — fired by `p`
    .../tui --open-link   <uuid>      # internal — fired by `o`
    .../tui --set-link    <uuid>      # internal — fired by `l`
    .../tui --open-plink  <uuid>      # internal — fired by `O`
    .../tui --set-plink   <uuid>      # internal — fired by `L`
    .../tui --delete-menu <uuid>      # internal — fired by `D`
    .../tui --list-rows [--toggle]    # internal — fired by Tab reload

Modes:
    NAV mode (default)   action keys are bound — j/k navigate, p/o/l/O/L
                         trigger actions, q closes the picker.
    SEARCH mode          enter with `/`. Action keys are unbound so every
                         letter (including j, k, p, q, L, …) types into
                         the fuzzy filter. Press <Esc> to return to NAV.

Bindings (shown as --header in the picker itself):
    /            switch to SEARCH mode (type to fuzzy-filter)
    Esc          return to NAV mode (clears query)
    ⏎            open task note (~/.task/notes/<uuid>.norg)
    p            open project note (~/.task/notes/projects/<project>.norg)
    o / l        open task link    /  set task link from clipboard
    O / L        open project link /  set project link from clipboard
    Tab          toggle pending ↔ pending + completed + deleted
    j / k        down / up
    q / Ctrl-C   close

Storage:
    Task link    → `link` UDA on the task (taskwarrior).
    Project link → ~/.task/notes/projects/<project>.link  (single-line text).
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

NOTE_DIR = Path.home() / ".task" / "notes"
PROJ_DIR = NOTE_DIR / "projects"
STATE_FILE = Path("/tmp/.taskwarrior-tui-show-all")

# 0x96f truecolor palette
P_  = "\033[38;2;174;163;230m"  # purple_light: id, urgency, project-note icon
CY  = "\033[38;2;174;232;244m"  # cyan: task-note icon
FG  = "\033[38;2;252;252;252m"  # fg: description
DM  = "\033[38;2;107;107;107m"  # comment: dim text
GR  = "\033[38;2;188;223;89m"   # green_light: tags, completed id
RED = "\033[38;2;255;114;114m"  # red: deleted id
OR  = "\033[38;2;252;157;111m"  # orange: project name
YL  = "\033[38;2;255;202;88m"   # yellow: link icon
B   = "\033[1m"
STR = "\033[9m"   # strikethrough — for deleted descriptions
R   = "\033[0m"

# Nerd Font icons (PUA codepoints; rendered by Nerd Font, 1 cell each)
ICON_NOTE    = ""  # nf-fa-file        — task has a note
ICON_PROJECT = ""  # nf-fa-folder      — project has a note
ICON_LINK    = ""  # nf-fa-link        — task or project has a link
ICON_PLINK   = ""  # same glyph, different color (green) for project link

EDITOR = os.environ.get("EDITOR") or "nvim"

HEADER_HINTS = (
    f"  {B}/{R} search   {B}j/k{R} nav   {B}⏎{R} note   "
    f"{B}p{R} proj-note   {B}o{R}/{B}l{R} task link   "
    f"{B}O{R}/{B}L{R} project link   "
    f"{B}D{R} delete…   {B}⇥{R} pending/all   {B}q{R} close"
)


def project_link_file(project: str) -> Path:
    return PROJ_DIR / f"{project}.link"


def project_has_link(project: str) -> bool:
    return bool(project) and project_link_file(project).is_file()


def read_project_link(project: str) -> str | None:
    p = project_link_file(project)
    if not p.is_file():
        return None
    try:
        value = p.read_text(encoding="utf-8").strip()
    except OSError:
        return None
    return value or None


def write_project_link(project: str, value: str) -> None:
    PROJ_DIR.mkdir(parents=True, exist_ok=True)
    project_link_file(project).write_text(value + "\n", encoding="utf-8")


def age(iso: str) -> str:
    if not iso:
        return ""
    try:
        dt = datetime.strptime(iso, "%Y%m%dT%H%M%SZ").replace(tzinfo=timezone.utc)
    except ValueError:
        return ""
    diff = max(0, int((datetime.now(timezone.utc) - dt).total_seconds()))
    if diff < 60:           return f"{diff}s"
    if diff < 3600:         return f"{diff // 60}m"
    if diff < 86400:        return f"{diff // 3600}h"
    if diff < 86400 * 30:   return f"{diff // 86400}d"
    if diff < 86400 * 365:  return f"{diff // 86400 // 30}mo"
    return f"{diff // 86400 // 365}y"


def task_export(show_all: bool) -> list[dict]:
    cmd = ["task", "rc.verbose=nothing", "rc.confirmation=no"]
    if not show_all:
        cmd.append("status:pending")
    cmd.append("export")
    out = subprocess.run(cmd, capture_output=True, text=True)
    if out.returncode != 0 or not out.stdout.strip():
        return []
    try:
        return json.loads(out.stdout)
    except json.JSONDecodeError:
        return []


def trunc(s: str, w: int) -> str:
    if w <= 0:
        return ""
    return s if len(s) <= w else s[: max(0, w - 1)] + "…"


def sanitize(s: str) -> str:
    """Collapse newlines/tabs/runs of whitespace so each cell stays on one line."""
    return " ".join((s or "").split())


def is_show_all() -> bool:
    return STATE_FILE.exists()


def toggle_state() -> None:
    if STATE_FILE.exists():
        STATE_FILE.unlink()
    else:
        STATE_FILE.touch()


def status_sort_key(t: dict) -> tuple:
    order = {"pending": 0, "completed": 1, "deleted": 2}
    s = order.get(t.get("status", ""), 99)
    if s == 0:
        return (s, -t.get("urgency", 0))
    # For non-pending, show most-recently-modified first.
    raw = t.get("end") or t.get("modified") or ""
    return (s, -int(raw[:14].replace("T", "").rstrip("Z") or 0))


def render_input(show_all: bool) -> str:
    """Build the fzf input string (header line + body lines, joined by \\n)."""
    tasks = task_export(show_all)
    tasks.sort(key=status_sort_key)

    cells: list[dict] = []
    for t in tasks:
        uuid = t.get("uuid", "")
        project = sanitize(t.get("project", "") or "")
        cells.append({
            "uuid":        uuid,
            "status":      t.get("status", "pending"),
            "id":          str(t.get("id", "")) or "—",  # done/deleted lose the numeric id
            "icon_note":   ICON_NOTE    if (NOTE_DIR / f"{uuid}.norg").is_file()       else " ",
            "icon_proj":   ICON_PROJECT if project and (PROJ_DIR / f"{project}.norg").is_file() else " ",
            "icon_link":   ICON_LINK    if (t.get("link") or "").strip()               else " ",
            "icon_plink":  ICON_PLINK   if project_has_link(project)                   else " ",
            "project":     project,
            "description": sanitize(t.get("description", "") or ""),
            "tags":        sanitize(",".join(t.get("tags", []) or [])),
            "age":         age(t.get("entry", "")),
            "urgency":     f"{t.get('urgency', 0):.2f}",
        })

    cols    = ["id", "icon_note", "icon_proj", "icon_link", "icon_plink",
               "project", "description", "tags", "age", "urgency"]
    headers = {"id": "ID", "icon_note": "", "icon_proj": "", "icon_link": "", "icon_plink": "",
               "project": "PROJECT", "description": "DESCRIPTION",
               "tags": "TAGS", "age": "AGE", "urgency": "URG"}
    caps    = {"id": 4, "icon_note": 1, "icon_proj": 1, "icon_link": 1, "icon_plink": 1,
               "project": 28, "description": 50, "tags": 16, "age": 6, "urgency": 6}
    aligns  = {"id": ">", "icon_note": "^", "icon_proj": "^",
               "icon_link": "^", "icon_plink": "^",
               "project": "<", "description": "<", "tags": "<",
               "age": ">", "urgency": ">"}

    widths = {k: len(headers[k]) for k in cols}
    for c in cells:
        for k in cols:
            widths[k] = max(widths[k], len(c[k]))
    for k in cols:
        widths[k] = min(widths[k], caps[k])

    SEP = "  "

    def color_for(c: dict, k: str) -> str:
        st = c["status"]
        if k == "id":
            if st == "completed": return GR
            if st == "deleted":   return RED + DM
            return P_
        if k == "description":
            if st == "deleted":   return DM + STR
            if st == "completed": return DM
            return FG
        # Non-pending rows render every other column dim so pending stays prominent.
        if st != "pending":
            return DM
        return {"icon_note": CY, "icon_proj": P_,
                "icon_link": YL, "icon_plink": GR,
                "project": OR, "tags": GR, "age": DM, "urgency": P_}[k]

    header_line = B + SEP.join(
        f"{trunc(headers[k], widths[k]):{aligns[k]}{widths[k]}}" for k in cols
    ) + R

    body_lines: list[str] = []
    for c in cells:
        parts = [
            f"{color_for(c, k)}{trunc(c[k], widths[k]):{aligns[k]}{widths[k]}}{R}"
            for k in cols
        ]
        body_lines.append(SEP.join(parts) + f"\t{c['uuid']}")

    return "\n".join([header_line] + body_lines)


def open_project_of(uuid: str) -> int:
    """Invoked by the fzf `p` binding in a child shell."""
    if not uuid:
        return 1
    out = subprocess.run(
        ["task", "_get", f"{uuid}.project"],
        capture_output=True, text=True,
    )
    project = out.stdout.strip()
    if not project:
        print("Task has no project", file=sys.stderr)
        return 1
    PROJ_DIR.mkdir(parents=True, exist_ok=True)
    path = PROJ_DIR / f"{project}.norg"
    os.execvp(EDITOR, [EDITOR, str(path)])
    return 0  # unreachable


def open_link_of(uuid: str) -> int:
    """Invoked by the fzf `o` binding. Opens URL or file path via macOS `open`."""
    if not uuid:
        return 1
    out = subprocess.run(["task", "_get", f"{uuid}.link"], capture_output=True, text=True)
    link = out.stdout.strip()
    if not link:
        print("Task has no link (use `l` to set one from clipboard)", file=sys.stderr)
        return 1
    subprocess.run(["open", link])
    return 0


def _resolve_link_value(value: str) -> str:
    """Turn a relative path into absolute so `open` works from anywhere later."""
    if value.startswith(("http://", "https://", "ftp://", "file://")) or value.startswith("/"):
        return value
    p = Path(value).expanduser()
    return str(p.resolve()) if p.exists() else value


def _clipboard() -> str:
    pb = subprocess.run(["pbpaste"], capture_output=True, text=True)
    return (pb.stdout or "").strip()


def set_link_of(uuid: str) -> int:
    """Invoked by the fzf `l` binding. Sets link UDA from current clipboard."""
    if not uuid:
        return 1
    value = _clipboard()
    if not value:
        print("Clipboard is empty — nothing to set", file=sys.stderr)
        return 1
    value = _resolve_link_value(value)
    res = subprocess.run(
        ["task", "rc.confirmation=no", "rc.verbose=nothing", uuid, "modify", f"link:{value}"],
        capture_output=True, text=True,
    )
    if res.returncode != 0:
        print(res.stderr.strip() or "task modify failed", file=sys.stderr)
        return res.returncode
    print(f"task link set: {value}")
    return 0


def _project_of(uuid: str) -> str | None:
    out = subprocess.run(["task", "_get", f"{uuid}.project"], capture_output=True, text=True)
    p = out.stdout.strip()
    return p or None


def open_plink_of(uuid: str) -> int:
    """Invoked by the fzf `O` binding. Opens the project's stored link."""
    if not uuid:
        return 1
    project = _project_of(uuid)
    if not project:
        print("Task has no project", file=sys.stderr)
        return 1
    link = read_project_link(project)
    if not link:
        print(f"Project '{project}' has no link (use `L` to set one from clipboard)",
              file=sys.stderr)
        return 1
    subprocess.run(["open", link])
    return 0


def set_plink_of(uuid: str) -> int:
    """Invoked by the fzf `L` binding. Sets the project's stored link from clipboard."""
    if not uuid:
        return 1
    project = _project_of(uuid)
    if not project:
        print("Task has no project — cannot set project link", file=sys.stderr)
        return 1
    value = _clipboard()
    if not value:
        print("Clipboard is empty — nothing to set", file=sys.stderr)
        return 1
    value = _resolve_link_value(value)
    write_project_link(project, value)
    print(f"project '{project}' link set: {value}")
    return 0


def _confirm(prompt: str) -> bool:
    try:
        ans = input(f"{prompt} [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        return False
    return ans.startswith("y")


def delete_note_of(uuid: str) -> int:
    """Invoked by Alt-n. Removes ~/.task/notes/<uuid>.norg and clears `note:` UDA."""
    if not uuid:
        return 1
    note = NOTE_DIR / f"{uuid}.norg"
    if not note.is_file():
        print("Task has no note to delete", file=sys.stderr)
        return 1
    desc = subprocess.run(["task", "_get", f"{uuid}.description"],
                          capture_output=True, text=True).stdout.strip() or uuid
    if not _confirm(f"Delete task note for '{desc}'?"):
        print("aborted")
        return 0
    try:
        note.unlink()
    except OSError as e:
        print(f"failed: {e}", file=sys.stderr)
        return 1
    subprocess.run(
        ["task", "rc.confirmation=no", "rc.verbose=nothing", uuid, "modify", "note:"],
        capture_output=True,
    )
    print("task note deleted")
    return 0


def delete_pnote_of(uuid: str) -> int:
    """Invoked by Alt-Shift-n. Removes ~/.task/notes/projects/<project>.norg."""
    if not uuid:
        return 1
    project = _project_of(uuid)
    if not project:
        print("Task has no project", file=sys.stderr)
        return 1
    pnote = PROJ_DIR / f"{project}.norg"
    if not pnote.is_file():
        print(f"Project '{project}' has no note to delete", file=sys.stderr)
        return 1
    if not _confirm(f"Delete project note for '{project}'?"):
        print("aborted")
        return 0
    try:
        pnote.unlink()
    except OSError as e:
        print(f"failed: {e}", file=sys.stderr)
        return 1
    print(f"project '{project}' note deleted")
    return 0


def delete_link_of(uuid: str) -> int:
    """Invoked by Alt-l. Clears the task's `link` UDA."""
    if not uuid:
        return 1
    res = subprocess.run(
        ["task", "rc.confirmation=no", "rc.verbose=nothing", uuid, "modify", "link:"],
        capture_output=True, text=True,
    )
    if res.returncode != 0:
        print(res.stderr.strip() or "task modify failed", file=sys.stderr)
        return res.returncode
    print("task link cleared")
    return 0


def delete_plink_of(uuid: str) -> int:
    """Removes ~/.task/notes/projects/<project>.link."""
    if not uuid:
        return 1
    project = _project_of(uuid)
    if not project:
        print("Task has no project", file=sys.stderr)
        return 1
    plink = project_link_file(project)
    if not plink.is_file():
        print(f"Project '{project}' has no link to delete", file=sys.stderr)
        return 1
    try:
        plink.unlink()
    except OSError as e:
        print(f"failed: {e}", file=sys.stderr)
        return 1
    print(f"project '{project}' link deleted")
    return 0


def delete_menu_of(uuid: str) -> int:
    """Invoked by `D`. Opens a small fzf sub-picker listing what's deletable
    on the current task; the user picks one and the corresponding delete runs."""
    if not uuid:
        return 1

    project  = _project_of(uuid) or ""
    has_note  = (NOTE_DIR / f"{uuid}.norg").is_file()
    has_pnote = bool(project) and (PROJ_DIR / f"{project}.norg").is_file()
    link      = subprocess.run(
        ["task", "_get", f"{uuid}.link"], capture_output=True, text=True
    ).stdout.strip()
    has_link  = bool(link)
    has_plink = bool(project) and project_has_link(project)

    options: list[tuple[str, str]] = []
    if has_note:
        options.append(("note",  "Task note"))
    if has_pnote:
        options.append(("pnote", f"Project note   ({project})"))
    if has_link:
        options.append(("link",  f"Task link      ({link[:60]})"))
    if has_plink:
        plink_val = read_project_link(project) or ""
        options.append(("plink", f"Project link   ({project} → {plink_val[:50]})"))

    if not options:
        print("Nothing to delete on this task", file=sys.stderr)
        return 0

    fzf_input = "\n".join(f"{key}\t{label}" for key, label in options)
    res = subprocess.run(
        [
            "fzf",
            "--ansi", "--layout=reverse", "--no-sort",
            "--prompt", "delete what? ",
            "--pointer", " ",
            "--height", "40%", "--margin", "5,15%", "--padding", "1,2",
            "--border", "rounded", "--border-label", " Delete ",
            "--border-label-pos", "top",
            "--info", "hidden",
            "--color", "border:white,label:red,prompt:bright-red,"
                       "fg+:-1,bg+:#FFFFFF,hl+:-1,gutter:-1",
            "--delimiter", "\t", "--with-nth", "2",
        ],
        input=fzf_input, capture_output=True, text=True,
    )
    if res.returncode != 0 or not res.stdout.strip():
        return 0
    choice = res.stdout.rstrip("\n").split("\t", 1)[0]

    return {
        "note":  delete_note_of,
        "pnote": delete_pnote_of,
        "link":  delete_link_of,
        "plink": delete_plink_of,
    }[choice](uuid)


def main() -> int:
    if len(sys.argv) >= 3 and sys.argv[1] == "--project-of":
        return open_project_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--open-link":
        return open_link_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--set-link":
        return set_link_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--open-plink":
        return open_plink_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--set-plink":
        return set_plink_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--delete-note":
        return delete_note_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--delete-pnote":
        return delete_pnote_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--delete-link":
        return delete_link_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--delete-plink":
        return delete_plink_of(sys.argv[2])
    if len(sys.argv) >= 3 and sys.argv[1] == "--delete-menu":
        return delete_menu_of(sys.argv[2])

    if "--list-rows" in sys.argv:
        if "--toggle" in sys.argv:
            toggle_state()
        sys.stdout.write(render_input(is_show_all()))
        return 0

    if not shutil.which("fzf"):
        print("fzf not found in PATH", file=sys.stderr)
        return 1

    NOTE_DIR.mkdir(parents=True, exist_ok=True)
    PROJ_DIR.mkdir(parents=True, exist_ok=True)

    # Each TUI session starts in pending-only mode.
    if STATE_FILE.exists():
        STATE_FILE.unlink()

    if not task_export(False):
        print("No pending tasks", file=sys.stderr)
        return 0

    self_path = os.path.realpath(__file__)

    # Keys that act as commands in NAV mode and as typed letters in SEARCH mode.
    # `/` is the entry to SEARCH; rebound when SEARCH exits via <Esc>.
    NAV_KEYS = ["j", "k", "p", "o", "l", "O", "L", "D", "q", "/"]
    unbind = "unbind(" + ",".join(NAV_KEYS) + ")"
    rebind = "rebind(" + ",".join(NAV_KEYS) + ")"

    binds = [
        ("j",   "down"),
        ("k",   "up"),
        ("p",   f"execute(python3 {self_path} --project-of  {{2}})+abort"),
        ("o",   f"execute(python3 {self_path} --open-link   {{2}})+abort"),
        ("l",   f"execute(python3 {self_path} --set-link    {{2}})"
                f"+reload(python3 {self_path} --list-rows)"),
        ("O",   f"execute(python3 {self_path} --open-plink  {{2}})+abort"),
        ("L",   f"execute(python3 {self_path} --set-plink   {{2}})"
                f"+reload(python3 {self_path} --list-rows)"),
        # Single delete key opens a sub-picker listing what's deletable.
        ("D",   f"execute(python3 {self_path} --delete-menu {{2}})"
                f"+reload(python3 {self_path} --list-rows)"),
        ("q",   "abort"),
        ("tab", f"reload(python3 {self_path} --list-rows --toggle)"),
        # Mode switches:
        ("/",   f"{unbind}+change-prompt(/ )"),
        ("esc", f"{rebind}+clear-query+change-prompt(  )"),
    ]
    bind_args: list[str] = []
    for key, action in binds:
        bind_args += ["--bind", f"{key}:{action}"]

    fzf = subprocess.run(
        [
            "fzf",
            "--ansi",
            "--layout=reverse",
            "--no-sort",
            "--header-lines=1",
            "--header", HEADER_HINTS,
            "--prompt", "  ",
            "--pointer", " ",
            "--height", "80%",
            "--margin", "2,10%",
            "--padding", "1,2",
            "--border", "rounded",
            "--border-label", " Taskwarrior — pending tasks ",
            "--border-label-pos", "top",
            "--info", "inline-right",
            "--color", "border:white,label:cyan,prompt:bright-magenta,"
                       "header:bright-blue,info:bright-black,gutter:-1,"
                       "fg+:-1,bg+:#FFFFFF,hl+:-1",
            "--delimiter", "\t",
            "--with-nth", "1",
            *bind_args,
        ],
        input=render_input(show_all=False), capture_output=True, text=True,
    )

    if fzf.returncode != 0 or not fzf.stdout.strip():
        return 0

    fields = fzf.stdout.rstrip("\n").split("\t")
    if len(fields) < 2:
        return 0
    uuid = fields[1].strip()
    if not uuid:
        return 0

    note = NOTE_DIR / f"{uuid}.norg"
    subprocess.run([EDITOR, str(note)])
    ts = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    subprocess.run(
        ["task", uuid, "mod", f"note:{ts}"],
        capture_output=True,
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
