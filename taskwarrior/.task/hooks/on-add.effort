#!/usr/bin/env python3
"""Compute effort_score = (1/effort)*2 on task add."""

import json
import sys

task = json.loads(sys.stdin.readline())

effort = task.get("effort")
if effort and float(effort) > 0:
    task["effort_score"] = round(2.0 / float(effort), 4)
else:
    task.pop("effort_score", None)

print(json.dumps(task))
