# Plantilla de secretos. Copia este archivo a secrets.zsh (mismo directorio) y
# rellena los valores reales. secrets.zsh está en .gitignore y NUNCA se versiona.
#
#   cp secrets.zsh.example secrets.zsh
#   $EDITOR secrets.zsh
#
# El loop de ~/.zshrc carga ~/.config/zsh/conf.d/*.zsh automáticamente al abrir
# la terminal, así que basta con crear secrets.zsh para que estas vars existan.

export GEMINI_API_KEY="TU_GEMINI_API_KEY_AQUI"            # Google AI Studio
export GOOGLE_GENERATIVE_AI_API_KEY="TU_GOOGLE_GENAI_KEY_AQUI"  # Google AI Studio
export OPENAI_API_KEY="TU_OPENAI_API_KEY_AQUI"            # platform.openai.com
