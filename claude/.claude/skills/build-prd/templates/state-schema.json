{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "build-prd state schema",
  "description": "Schema del archivo .build-prd-state.json que persiste el progreso de la entrevista entre sesiones.",
  "type": "object",
  "required": ["version", "iniciado_en", "actualizado_en", "step_actual", "ruta_salida", "meta", "secciones"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "iniciado_en": { "type": "string", "format": "date-time" },
    "actualizado_en": { "type": "string", "format": "date-time" },
    "step_actual": { "type": "integer", "minimum": 0, "maximum": 17 },
    "completa": { "type": "boolean", "default": false },
    "ruta_salida": { "type": "string", "description": "Ruta absoluta del archivo PRD final" },
    "meta": {
      "type": "object",
      "properties": {
        "proyecto": { "type": "string" },
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "version": { "type": "string", "default": "0.1" },
        "fecha": { "type": "string", "format": "date" },
        "tipo": { "type": "string", "enum": ["MVP", "POC", "Producto v1", "Iteración mayor"] },
        "enfoque": { "type": "string" },
        "subtitulo": { "type": "string" },
        "empresa": { "type": ["string", "null"] },
        "programa": { "type": ["string", "null"] },
        "confidencialidad": { "type": "string", "enum": ["Uso interno", "Confidencial", "Público", "Restringido"] }
      }
    },
    "secciones": {
      "type": "object",
      "description": "Cada step tiene su propio sub-objeto con el estado capturado",
      "patternProperties": {
        "^[0-9]{2}$": {
          "type": "object",
          "properties": {
            "completa": { "type": "boolean" },
            "datos": { "type": "object" },
            "markdown": { "type": "string", "description": "Markdown final aprobado por el usuario para esta sección" }
          }
        }
      }
    },
    "pendientes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["seccion", "campo", "nota"],
        "properties": {
          "seccion": { "type": "string" },
          "campo": { "type": "string" },
          "nota": { "type": "string" }
        }
      }
    }
  }
}
