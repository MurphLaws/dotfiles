# Font Configuration
font-family = JetBrainsMono Nerd Font Mono
font-style = Bold
font-style-bold = ExtraBold

font-size = 20
font-thicken = true

# Theme — Catppuccin Macchiato
background = 24273a
foreground = cad3f5
cursor-color = f4dbd6
cursor-text = 24273a
selection-background = 5b6078
selection-foreground = cad3f5

# ANSI palette (Catppuccin Macchiato)
palette = 0=#494d64
palette = 1=#ed8796
palette = 2=#a6da95
palette = 3=#eed49f
palette = 4=#8aadf4
palette = 5=#f5bde6
palette = 6=#8bd5ca
palette = 7=#b8c0e0
palette = 8=#5b6078
palette = 9=#ed8796
palette = 10=#a6da95
palette = 11=#eed49f
palette = 12=#8aadf4
palette = 13=#f5bde6
palette = 14=#8bd5ca
palette = 15=#a5adcb

# Window — fullscreen no-nativo: "pantalla completa" es una ventana maximizada
# en el Space actual (no un Space aparte), así QuartoSplit puede dividirla.
macos-non-native-fullscreen = true

# Background fully opaque
#   No transparency, no blur — solid background color matching Catppuccin Macchiato.
background-opacity = 1

# Fondo con degradado azul (PNG generado con ImageMagick:
#   magick -size 1920x1080 gradient:'#10141f'-'#2e3a52' gradient-blue.png)
# background-image-opacity < 1 lo mezcla con el background 24273a.
background-image = ~/.config/ghostty/backgrounds/gradient-blue.png
background-image-fit = cover
background-image-opacity = 0.7

# Shaders (GLSL) — método builtin de Ghostty (custom-shader)
#   1) CRT retro sutil (scanlines + bloom + viñeta, conserva Catppuccin)
#   2) animación de cursor tipo "smear" (estilo Neovide)
# El CRT va PRIMERO; el cursor smear se dibuja encima.
custom-shader = shaders/retro-crt.glsl
custom-shader = shaders/cursor-smear.glsl
# false = los shaders solo se redibujan cuando cambia la pantalla, no en bucle
# continuo: en reposo la GPU baja a 0 FPS (menos batería/calor). Coste: el
# cursor-smear pierde su animación fluida (el CRT estático no se ve afectado).
custom-shader-animation = false

keybind = shift+enter=text:\x1b\r

# Auto-start tmux
command = /opt/homebrew/bin/tmux new-session -A -s main-$RANDOM
